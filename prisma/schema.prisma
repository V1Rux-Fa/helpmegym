generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}
datasource db {
  provider = "postgresql"
}
model User { 
  id    Int     @id @default(autoincrement()) 
  email String  @unique
  name  String?
  exercise Exercise[]
} 
model Exercise { 
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  authorId  Int
  author    User    @relation(fields: [authorId], references: [id]) 
} 